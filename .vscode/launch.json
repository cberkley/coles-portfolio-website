{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Attach to .NET Functions",
            "type": "coreclr",
            "request": "attach",
            "processId": "${command:pickProcess}",
            "preLaunchTask": "func: host start",
            "presentation": {
                "hidden": false,
                "group": "Functions",
                "order": 1
            }
        },
        {
            "name": "Launch .NET Functions",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${env:DOTNET_ROOT}/dotnet",
            "args": [
                "run",
                "--project",
                "${workspaceFolder}/functions/PortfolioFunctions/PortfolioFunctions.csproj"
            ],
            "cwd": "${workspaceFolder}/functions/PortfolioFunctions",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Host lock lease acquired"
            },
            "env": {
                "AZURE_FUNCTIONS_ENVIRONMENT": "Development"
            }
        }
    ]
}
